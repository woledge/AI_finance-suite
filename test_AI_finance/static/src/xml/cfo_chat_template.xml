<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Virtual CFO ChatGPT-Style Chat Template with Sidebar -->
    <t t-name="test_AI_finance.VirtualCFOChat">
        <div class="cfo-chat-wrapper">
            <!-- Sidebar -->
            <div t-att-class="'cfo-sidebar ' + (state.showSidebar ? 'open' : 'closed')">
                <div class="sidebar-header">
                    <button class="new-chat-btn" t-on-click="newChat">
                        <i class="fa fa-plus"/> New Chat
                    </button>
                    <button class="toggle-sidebar-btn" t-on-click="toggleSidebar">
                        <i class="fa fa-chevron-left"/>
                    </button>
                </div>
                
                <div class="sidebar-sessions">
                    <div class="sessions-label">Chat History</div>
                    <t t-foreach="state.chatSessions" t-as="session" t-key="session.id">
                        <div t-att-class="'session-item ' + (session.id === state.cfoAgentId ? 'active' : '')"
                             t-on-click="() => this.selectSession(session.id)">
                            <i class="fa fa-comments-o"/>
                            <div class="session-info">
                                <span class="session-name" t-esc="session.name"/>
                                <span class="session-meta">
                                    <t t-esc="session.date"/> • <t t-esc="session.queryCount"/> msgs
                                </span>
                            </div>
                            <button class="session-delete-btn" 
                                    t-on-click="(ev) => this.deleteSession(session.id, ev)"
                                    title="Delete chat">
                                <i class="fa fa-trash-o"/>
                            </button>
                        </div>
                    </t>
                    <div t-if="state.chatSessions.length === 0" class="no-sessions">
                        No previous chats
                    </div>
                </div>
            </div>
            
            <!-- Toggle button when sidebar is closed -->
            <button t-if="!state.showSidebar" 
                    class="sidebar-open-btn" 
                    t-on-click="toggleSidebar"
                    title="Show chat history">
                <i class="fa fa-chevron-right"/>
            </button>
            
            <!-- Main Chat Area -->
            <div class="cfo-chat-container">
                <!-- Chat Header -->
                <div class="cfo-chat-header">
                    <div class="cfo-header-left">
                        <div class="cfo-avatar-icon">
                            <i class="fa fa-line-chart"/>
                        </div>
                        <div class="cfo-header-info">
                            <h4>Virtual CFO</h4>
                            <span class="cfo-status">
                                <span class="status-dot" t-att-class="state.isLoading ? 'typing' : 'online'"/>
                                <t t-if="state.isLoading">Thinking...</t>
                                <t t-else="">
                                    <t t-esc="state.currentSessionName"/>
                                </t>
                            </span>
                        </div>
                    </div>
                    <div class="cfo-header-actions">
                        <button class="btn btn-sm btn-outline-secondary" 
                                t-on-click="clearHistory" title="Clear conversation">
                            <i class="fa fa-trash-o"/>
                        </button>
                    </div>
                </div>
                
                <!-- Chat Messages -->
                <div class="cfo-chat-messages" t-ref="chatContainer">
                    <!-- Empty State -->
                    <div t-if="state.messages.length === 0" class="cfo-empty-state">
                        <div class="empty-state-icon">
                            <i class="fa fa-line-chart"/>
                        </div>
                        <h2>Virtual CFO V1</h2>
                        <p>I can help you analyze your financial data. Try asking:</p>
                        
                        <div class="cfo-suggestions-centered">
                            <button class="chip" t-on-click="askSales">
                                📊 Total Sales
                            </button>
                            <button class="chip" t-on-click="askExpenses">
                                💸 Expenses
                            </button>
                            <button class="chip" t-on-click="askCashPosition">
                                💰 Cash Position
                            </button>
                            <button class="chip" t-on-click="askOverdue">
                                ⏰ Overdue
                            </button>
                            <button class="chip" t-on-click="askProfit">
                                📈 Profit
                            </button>
                        </div>
                    </div>

                    <t t-foreach="state.messages" t-as="message" t-key="message_index">
                        <div t-att-class="'cfo-message ' + message.type">
                            <div class="message-avatar">
                                <t t-if="message.type === 'user'">
                                    <i class="fa fa-user"/>
                                </t>
                                <t t-elif="message.type === 'assistant'">
                                    <i class="fa fa-line-chart"/>
                                </t>
                                <t t-elif="message.type === 'error'">
                                    <i class="fa fa-exclamation-circle"/>
                                </t>
                                <t t-else="">
                                    <i class="fa fa-info-circle"/>
                                </t>
                            </div>
                            <div class="message-content">
                                <div class="message-bubble" 
                                     t-att-class="message.type === 'error' ? 'error' : ''"
                                     t-out="formatMessage(message.content)"/>
                                <!-- Copy button for assistant messages -->
                                <div t-if="message.type === 'assistant'" class="message-actions">
                                    <button class="msg-action-btn" 
                                            t-on-click="() => this.copyMessage(message_index)"
                                            title="Copy response">
                                        <i class="fa fa-copy"/> Copy
                                    </button>
                                </div>
                                <!-- Retry button for error messages -->
                                <div t-if="message.type === 'error'" class="message-actions">
                                    <button class="msg-action-btn retry-btn" 
                                            t-on-click="retryLastMessage"
                                            title="Retry last question">
                                        <i class="fa fa-refresh"/> Retry
                                    </button>
                                </div>
                            </div>
                        </div>
                    </t>
                    
                    <!-- Typing Indicator -->
                    <div t-if="state.isLoading" class="cfo-message assistant">
                        <div class="message-avatar">
                            <i class="fa fa-line-chart"/>
                        </div>
                        <div class="message-content">
                            <div class="typing-indicator">
                                <span class="dot"/>
                                <span class="dot"/>
                                <span class="dot"/>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Chat Input -->
                <div class="cfo-chat-input">
                    <div class="input-wrapper">
                        <textarea 
                            t-ref="chatInput"
                            t-model="state.inputText"
                            t-on-keydown="onKeyDown"
                            placeholder="Ask about your finances... (اسأل عن شؤونك المالية)"
                            rows="1"
                            t-att-disabled="state.isLoading"/>
                        <button 
                            class="send-btn" 
                            t-on-click="sendMessage"
                            t-att-disabled="state.isLoading or !state.inputText.trim()">
                            <i t-att-class="state.isLoading ? 'fa fa-spinner fa-spin' : 'fa fa-paper-plane'"/>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>
