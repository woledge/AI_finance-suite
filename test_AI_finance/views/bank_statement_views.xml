<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ==================== SEQUENCE ==================== -->
    <record id="seq_bank_statement" model="ir.sequence">
        <field name="name">Bank Statement Sequence</field>
        <field name="code">test.ai.bank.statement</field>
        <field name="prefix">BS/</field>
        <field name="padding">4</field>
    </record>

    <!-- ==================== BANK STATEMENT FORM VIEW ==================== -->
    <record id="view_bank_statement_form" model="ir.ui.view">
        <field name="name">test.ai.bank.statement.form</field>
        <field name="model">test.ai.bank.statement</field>
        <field name="arch" type="xml">
            <form string="Bank Statement Reconciliation">
                <header>
                    <button name="action_match_lines" string="Match Lines" type="object"
                            class="oe_highlight" invisible="state == 'reconciled'"/>
                    <button name="action_confirm_matches" string="Confirm Matches" type="object"
                            class="btn-success" invisible="state != 'processed'"/>
                    <button name="action_rematch" string="Re-match" type="object"
                            class="btn-warning" invisible="state == 'draft'"/>
                    <button name="action_print_report" string="Print Report" type="object"
                            class="btn-secondary" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,processed,reconciled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Bank Information">
                            <field name="bank_account_id"/>
                            <field name="bank_name"/>
                            <field name="account_number"/>
                            <field name="currency_id"/>
                        </group>
                        <group string="Balance Summary">
                            <field name="opening_balance"/>
                            <field name="closing_balance"/>
                            <field name="odoo_balance"/>
                            <field name="difference" decoration-danger="difference != 0"
                                   decoration-success="difference == 0"/>
                        </group>
                    </group>
                    <group string="Statement Period">
                        <group>
                            <field name="date_from"/>
                        </group>
                        <group>
                            <field name="date_to"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Statement Lines" name="lines">
                            <field name="line_ids">
                                <list editable="bottom"
                                      decoration-success="match_status == 'matched'"
                                      decoration-warning="match_status == 'ambiguous'"
                                      decoration-danger="match_status in ('missing_in_odoo', 'missing_in_bank')"
                                      decoration-muted="match_status == 'unmatched'">
                                    <field name="date"/>
                                    <field name="description"/>
                                    <field name="debit" sum="Total Debit"/>
                                    <field name="credit" sum="Total Credit"/>
                                    <field name="balance"/>
                                    <field name="matched_move_line_id"
                                           domain="[('id', 'in', candidate_move_line_ids)]"
                                           options="{'no_create': True}"/>
                                    <field name="matched_partner_id" optional="show"/>
                                    <field name="match_status"
                                           widget="badge"
                                           decoration-success="match_status == 'matched'"
                                           decoration-warning="match_status == 'ambiguous'"
                                           decoration-danger="match_status in ('missing_in_odoo', 'missing_in_bank')"/>
                                    <field name="match_notes" optional="hide"/>
                                    <field name="is_odoo_only" column_invisible="True"/>
                                    <field name="candidate_move_line_ids" column_invisible="True"/>
                                </list>
                            </field>
                        </page>
                        <page string="Reconciliation Summary" name="summary" invisible="state == 'draft'">
                            <group>
                                <group string="Match Statistics">
                                    <field name="summary_total_lines"/>
                                    <field name="summary_matched" decoration-success="summary_matched > 0"/>
                                    <field name="summary_match_rate" widget="progressbar"/>
                                </group>
                                <group string="Issues Found">
                                    <field name="summary_discrepancy" decoration-danger="summary_discrepancy > 0"/>
                                    <field name="summary_missing_odoo" decoration-danger="summary_missing_odoo > 0"/>
                                    <field name="summary_missing_bank" decoration-warning="summary_missing_bank > 0"/>
                                    <field name="summary_unresolved" decoration-danger="summary_unresolved > 0"/>
                                </group>
                            </group>
                        </page>
                        <page string="OCR Raw Data" name="ocr">
                            <field name="ocr_raw_text" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ==================== BANK STATEMENT TREE VIEW ==================== -->
    <record id="view_bank_statement_tree" model="ir.ui.view">
        <field name="name">test.ai.bank.statement.tree</field>
        <field name="model">test.ai.bank.statement</field>
        <field name="arch" type="xml">
            <list string="Bank Statements"
                  decoration-success="state == 'reconciled'"
                  decoration-info="state == 'processed'">
                <field name="name"/>
                <field name="bank_account_id"/>
                <field name="bank_name"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="opening_balance"/>
                <field name="closing_balance"/>
                <field name="difference" decoration-danger="difference != 0"/>
                <field name="currency_id"/>
                <field name="state"
                       widget="badge"
                       decoration-success="state == 'reconciled'"
                       decoration-info="state == 'processed'"
                       decoration-muted="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- ==================== ACTION ==================== -->
    <record id="action_bank_statement" model="ir.actions.act_window">
        <field name="name">Bank Statements</field>
        <field name="res_model">test.ai.bank.statement</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Upload a bank statement to reconcile
            </p>
            <p>
                Compare your bank statements against Odoo's bank journal entries.
                Upload via the OCR Engine wizard to auto-extract transactions.
            </p>
        </field>
    </record>

</odoo>
