<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Virtual CFO Agent Form View -->
    <record id="view_virtual_cfo_agent_form" model="ir.ui.view">
        <field name="name">test.ai.virtual.cfo.agent.form</field>
        <field name="model">test.ai.virtual.cfo.agent</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_recommendations" type="object"
                                class="oe_stat_button" icon="fa-lightbulb-o" invisible="1">
                            <field name="recommendation_count" widget="statinfo" 
                                   string="Recommendations"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="query_count"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <div class="oe_button_box mt-3">
                        <button name="action_new_conversation" type="object" 
                                string="Ask Question" class="btn-primary btn-lg"/>
                        <button name="action_generate_insights" type="object" 
                                string="Generate Insights" class="btn-secondary"/>
                    </div>
                    <notebook>
                        <page string="Conversations">
                            <field name="conversation_ids">
                                <list>
                                    <field name="create_date"/>
                                    <field name="question"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Virtual CFO Action -->
    <record id="action_virtual_cfo_agent" model="ir.actions.act_window">
        <field name="name">Virtual CFO (TEST)</field>
        <field name="res_model">test.ai.virtual.cfo.agent</field>
        <field name="view_mode">form</field>
    </record>

    <!-- CFO Query Wizard -->
    <record id="view_cfo_query_wizard_form" model="ir.ui.view">
        <field name="name">test.ai.cfo.query.wizard.form</field>
        <field name="model">test.ai.cfo.query.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group invisible="show_answer">
                    <field name="suggested_question"/>
                    <field name="question" placeholder="Ask any financial question..."/>
                    <field name="cfo_agent_id" invisible="1"/>
                </group>
                <group invisible="not show_answer">
                    <field name="question" readonly="1"/>
                    <field name="answer" nolabel="1"/>
                </group>
                <footer>
                    <button name="action_ask" type="object" 
                            string="Ask" class="btn-primary"
                            invisible="show_answer"/>
                    <button name="action_new_question" type="object" 
                            string="New Question"
                            invisible="not show_answer"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- AI Recommendation Views REMOVED for Simple Module -->

    <!-- Virtual CFO Chat (ChatGPT-Style) Client Action -->
    <record id="action_virtual_cfo_chat" model="ir.actions.client">
        <field name="name">💬 Virtual CFO Chat (TEST)</field>
        <field name="tag">test_virtual_cfo_chat</field>
    </record>
</odoo>

