<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==================== OCR ENGINE WIZARD FORM VIEW ==================== -->
    <record id="view_vendor_bill_wizard_form" model="ir.ui.view">
        <field name="name">test.ai.vendor.bill.wizard.form</field>
        <field name="model">test.ai.vendor.bill.wizard</field>
        <field name="arch" type="xml">
            <form string="OCR Engine">
                <!-- Hidden state and type fields -->
                <field name="state" invisible="1"/>
                <field name="document_type" invisible="1"/>
                
                <!-- ==================== SELECT TYPE STATE ==================== -->
                <div invisible="state != 'select_type'" class="oe_structure">
                    <div class="text-center mb-4">
                        <h2><i class="fa fa-file-text-o"/> OCR Engine</h2>
                        <p class="text-muted">Select the type of document you want to process</p>
                    </div>
                    
                    <group>
                        <group col="1">
                            <field name="document_type" widget="radio" 
                                   options="{'horizontal': false}"
                                   class="o_field_radio"/>
                        </group>
                    </group>
                    
                    <div class="alert alert-info mt-4" role="alert">
                        <strong>Vendor Bill:</strong> Create a new vendor bill from a received invoice.<br/>
                        <strong>Customer Invoice:</strong> Create a customer invoice from a bill you sent.<br/>
                        <strong>Refund:</strong> Track a cancelled ticket/booking until credit note received.<br/>
                        <strong>Statement:</strong> Match partner account statement with Odoo records.<br/>
                        <strong>Bank Statement:</strong> Reconcile bank statement with Odoo bank journal entries.
                    </div>
                </div>

                <!-- ==================== UPLOAD STATE ==================== -->
                <div invisible="state != 'upload'" class="oe_structure">
                    <!-- Vendor Bill Upload -->
                    <div invisible="document_type != 'vendor_bill'">
                        <div class="alert alert-info" role="alert">
                            <strong>Upload Vendor Bill:</strong> Upload an invoice image (PNG, JPG), PDF, or Excel file.
                            Our AI will extract vendor details, line items, amounts, and the <strong>Reference/Voucher Code</strong> for statement matching.
                        </div>
                    </div>

                    <!-- Customer Invoice Upload -->
                    <div invisible="document_type != 'customer_invoice'">
                        <div class="alert alert-success" role="alert">
                            <strong>Upload Customer Invoice:</strong> Upload a bill document from the partner.
                            Our AI will create a Customer Invoice in Odoo with the <strong>Reference/Voucher Code</strong> for statement matching.
                        </div>
                    </div>
                    
                    <!-- Refund Upload -->
                    <div invisible="document_type != 'refund'">
                        <div class="alert alert-warning" role="alert">
                            <strong>Upload Refund Document:</strong> Upload a cancellation confirmation, refund receipt, or ticket document.
                            We'll extract the ticket number, vendor, and refund amount to track until credit note is received.
                        </div>
                    </div>
                    
                    <!-- Statement Upload -->
                    <div invisible="document_type != 'statement'">
                        <div class="alert alert-primary" role="alert">
                            <strong>Upload Partner Statement:</strong> Upload a PDF or Excel account statement from your partner.
                            We'll match each line with your Odoo records using <strong>Voucher/Reference Codes</strong> and identify discrepancies.
                        </div>
                    </div>

                    <!-- Bank Statement Upload -->
                    <div invisible="document_type != 'bank_statement'">
                        <div class="alert alert-dark" role="alert">
                            <strong>Upload Bank Statement:</strong> Upload a PDF, image, or Excel bank statement.
                            We'll extract transactions and match them against your Odoo bank journal using <strong>amount + date</strong> matching.
                        </div>
                    </div>

                    <group>
                        <group>
                            <field name="invoice_file" filename="filename" required="state == 'upload'"/>
                            <field name="filename" invisible="1"/>
                        </group>
                        <group invisible="document_type != 'bank_statement'">
                            <field name="bank_account_id"/>
                        </group>
                    </group>
                    <group invisible="document_type != 'statement'">
                        <group>
                            <field name="manual_column_selection" widget="boolean_toggle"/>
                        </group>
                    </group>
                </div>

                <!-- ==================== PROCESSING STATE ==================== -->
                <div invisible="state != 'processing'" class="text-center">
                    <div class="fa fa-spin fa-spinner fa-3x mb-3"/>
                    <h3>Processing Document...</h3>
                    <p>Please wait while our AI extracts data from your document.</p>
                </div>

                <!-- ==================== REVIEW STATE (VENDOR BILL) ==================== -->
                <div invisible="state != 'review' or document_type != 'vendor_bill'">
                    <div class="alert alert-success" role="alert">
                        <strong>Review Vendor Bill:</strong> Check the extracted data below. Make any corrections, then click "Create Bill".
                    </div>
                    
                    <group>
                        <group string="Partner Information">
                            <field name="vendor_id" options="{'no_create_edit': False}"/>
                            <field name="vendor_name_extracted" readonly="1" invisible="vendor_id"/>
                        </group>
                        <group string="Invoice Details">
                            <field name="invoice_number"/>
                            <field name="reference_code"/>
                            <field name="invoice_date"/>
                            <field name="due_date"/>
                            <field name="currency_id"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Line Items" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="total"/>
                                </list>
                            </field>
                        </page>
                        <page string="Amounts" name="amounts">
                            <group>
                                <group>
                                    <field name="subtotal"/>
                                    <field name="tax_amount"/>
                                    <field name="total_amount"/>
                                </group>
                                <group>
                                    <field name="confidence_score" widget="percentage"/>
                                    <field name="processing_time"/>
                                </group>
                            </group>
                        </page>
                        <page string="Debug Info" name="debug" groups="base.group_no_one">
                            <field name="raw_ocr_text" readonly="1"/>
                        </page>
                    </notebook>
                </div>

                <!-- ==================== REVIEW STATE (REFUND) ==================== -->
                <div invisible="state != 'review' or document_type != 'refund'">
                    <div class="alert alert-warning" role="alert">
                        <strong>Review Refund Details:</strong> Verify the extracted refund information below, then click "Create Refund Tracking".
                    </div>
                    
                    <group>
                        <group string="Ticket Information">
                            <field name="ticket_number"/>
                            <field name="passenger_name"/>
                            <field name="flight_details"/>
                        </group>
                        <group string="Vendor &amp; Amount">
                            <field name="vendor_id" options="{'no_create_edit': False}"/>
                            <field name="vendor_name_extracted" readonly="1" invisible="vendor_id"/>
                            <field name="total_amount" string="Refund Amount"/>
                            <field name="currency_id"/>
                        </group>
                    </group>
                    
                    <group>
                        <group string="Refund Details">
                            <field name="refund_reason" placeholder="Reason for cancellation/refund..."/>
                            <field name="original_bill_id" options="{'no_create': True}"/>
                        </group>
                        <group string="Status">
                            <field name="refund_status"/>
                            <field name="invoice_date" string="Request Date"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Credit Items" name="refund_lines">
                            <field name="line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="total"/>
                                </list>
                            </field>
                        </page>
                        <page string="Amounts" name="refund_amounts">
                            <group>
                                <group>
                                    <field name="subtotal"/>
                                    <field name="tax_amount"/>
                                    <field name="total_amount" string="Total Credit"/>
                                </group>
                            </group>
                        </page>
                        <page string="OCR Info" name="ocr_info">
                            <group>
                                <group>
                                    <field name="confidence_score" widget="percentage"/>
                                    <field name="processing_time"/>
                                </group>
                            </group>
                        </page>
                        <page string="Debug Info" name="debug" groups="base.group_no_one">
                            <field name="raw_ocr_text" readonly="1"/>
                        </page>
                    </notebook>
                </div>

                <!-- ==================== REVIEW STATE (STATEMENT) ==================== -->
                <div invisible="state != 'review' or document_type != 'statement'">
                    <div class="alert alert-primary" role="alert">
                        <strong>Review Statement:</strong> Please verify partner and period dates below.
                        <strong>Select the Match Key Column</strong> — choose which column from the statement
                        should be used for matching against Odoo references.
                        Then click "Create Statement" to proceed with reconciliation.
                    </div>

                    <group>
                        <group string="Partner Information">
                            <field name="vendor_id" options="{'no_create_edit': False}" required="state == 'review' and document_type == 'statement'"/>
                            <field name="vendor_name_extracted" readonly="1" invisible="vendor_id"/>
                        </group>
                        <group string="Statement Details">
                            <field name="invoice_date" string="Statement Date"/>
                            <field name="total_amount" string="Total Due"/>
                            <field name="currency_id"/>
                        </group>
                    </group>
                    <group string="Statement Period (required for accurate matching)">
                        <group>
                            <field name="statement_date_from" required="state == 'review' and document_type == 'statement'"/>
                        </group>
                        <group>
                            <field name="statement_date_to" required="state == 'review' and document_type == 'statement'"/>
                        </group>
                    </group>
                    <group string="Matching Settings" invisible="not manual_column_selection">
                        <group>
                            <field name="column_ids" invisible="1"/>
                            <field name="selected_column_id"
                                   options="{'no_create': True, 'no_create_edit': True}"
                                   required="manual_column_selection and state == 'review' and document_type == 'statement'"/>
                        </group>
                    </group>
                </div>

                <!-- ==================== REVIEW STATE (BANK STATEMENT) ==================== -->
                <div invisible="state != 'review' or document_type != 'bank_statement'">
                    <div class="alert alert-dark" role="alert">
                        <strong>Review Bank Statement:</strong> Please select the bank account to match against, and verify the period dates.
                    </div>

                    <group>
                        <group string="Bank Account">
                            <field name="bank_account_id" required="state == 'review' and document_type == 'bank_statement'"/>
                        </group>
                        <group string="Statement Details">
                            <field name="invoice_date" string="Statement Date"/>
                            <field name="total_amount" string="Closing Balance"/>
                            <field name="currency_id"/>
                        </group>
                    </group>
                    <group string="Statement Period">
                        <group>
                            <field name="statement_date_from" required="state == 'review' and document_type == 'bank_statement'"/>
                        </group>
                        <group>
                            <field name="statement_date_to" required="state == 'review' and document_type == 'bank_statement'"/>
                        </group>
                    </group>
                </div>

                <!-- ==================== DONE STATE (VENDOR BILL) ==================== -->
                <div invisible="state != 'done' or document_type != 'vendor_bill'" class="text-center">
                    <div class="fa fa-check-circle fa-3x text-success mb-3"/>
                    <h3>Vendor Bill Created!</h3>
                    <p>The draft vendor bill has been created successfully.</p>
                    <field name="created_bill_id" readonly="1"/>
                </div>
                
                <!-- ==================== DONE STATE (REFUND) ==================== -->
                <!-- ==================== DONE STATE (REFUND) ==================== -->
                <!-- Refund Tracking Disabled in Test Module -->
                <!-- <div invisible="state != 'done' or document_type != 'refund'" class="text-center">
                    <div class="fa fa-check-circle fa-3x text-warning mb-3"/>
                    <h3>Refund Tracking Created!</h3>
                    <p>The refund is now being tracked. You'll be notified when the credit note is received.</p>
                    <field name="created_refund_id" readonly="1"/>
                </div> -->

                <!-- ==================== SINGLE FOOTER WITH CONDITIONAL BUTTONS ==================== -->
                <footer>
                    <!-- Select Type State -->
                    <button name="action_select_type" string="Continue" type="object" class="btn-primary"
                            invisible="state != 'select_type'"/>
                    
                    <!-- Upload State -->
                    <button name="action_process_file" string="Process Document" type="object" class="btn-primary"
                            invisible="state != 'upload'"/>
                    <button name="action_back_to_type" string="Back" type="object" class="btn-secondary"
                            invisible="state != 'upload'"/>
                    
                    <!-- Review State - Vendor Bill -->
                    <button name="action_create_bill" string="Create Vendor Bill" type="object" class="btn-primary"
                            invisible="state != 'review' or document_type != 'vendor_bill'"/>
                    
                    <!-- Review State - Refund -->
                    <!-- Review State - Refund -->
                    <!-- <button name="action_create_refund" string="Create Refund Tracking" type="object" class="btn-warning"
                            invisible="state != 'review' or document_type != 'refund'"/> -->
                    
                    <!-- Review State - Statement -->
                    <button name="action_create_statement_from_review" string="Create Statement" type="object" class="btn-primary"
                            invisible="state != 'review' or document_type != 'statement'"/>

                    <!-- Review State - Bank Statement -->
                    <button name="action_create_bank_statement" string="Create Bank Statement" type="object" class="btn-primary"
                            invisible="state != 'review' or document_type != 'bank_statement'"/>
                    
                    <!-- Review State - Back -->
                    <button name="action_back_to_upload" string="Back" type="object" class="btn-secondary"
                            invisible="state != 'review'"/>
                    
                    <!-- Cancel - Always available except in done state -->
                    <button string="Cancel" class="btn-secondary" special="cancel"
                            invisible="state == 'done'"/>
                    
                    <!-- Done State - Close -->
                    <button string="Close" class="btn-primary" special="cancel"
                            invisible="state != 'done'"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ==================== ACTION ==================== -->
    <record id="action_vendor_bill_wizard" model="ir.actions.act_window">
        <field name="name">OCR Engine</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">test.ai.vendor.bill.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_state': 'select_type'}</field>
    </record>

    <!-- ==================== MENU ITEM (in AI Finance) ==================== -->
    <!-- Duplicate menuitem removed. Defined in views/menu.xml -->

</odoo>
