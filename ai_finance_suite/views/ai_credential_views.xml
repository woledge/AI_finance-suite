<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Credential Form View -->
    <record id="view_ai_credential_form" model="ir.ui.view">
        <field name="name">af.credential.form</field>
        <field name="model">af.credential</field>
        <field name="arch" type="xml">
            <form string="AI Credential">
                <header>
                    <button name="action_test_connection" string="Test Connection" type="object" class="btn-primary"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. Gemini Production"/></h1>
                    </div>
                    <group>
                        <group string="Provider Configuration">
                            <field name="provider"/>
                            <!-- Per-provider model dropdowns -->
                            <field name="gemini_model" invisible="provider != 'gemini'"
                                   string="Model" required="provider == 'gemini'"/>
                            <field name="openai_model" invisible="provider != 'openai'"
                                   string="Model" required="provider == 'openai'"/>
                            <field name="groq_model" invisible="provider != 'groq'"
                                   string="Model" required="provider == 'groq'"/>
                            <field name="deepseek_model" invisible="provider != 'deepseek'"
                                   string="Model" required="provider == 'deepseek'"/>
                            <field name="claude_model" invisible="provider != 'claude'"
                                   string="Model" required="provider == 'claude'"/>
                            <field name="xai_model" invisible="provider != 'xai'"
                                   string="Model" required="provider == 'xai'"/>
                            <field name="mistral_model" invisible="provider != 'mistral'"
                                   string="Model" required="provider == 'mistral'"/>
                            <field name="cohere_model" invisible="provider != 'cohere'"
                                   string="Model" required="provider == 'cohere'"/>
                            <!-- Custom provider fields -->
                            <field name="custom_model_name" invisible="provider != 'custom'"
                                   string="Model Name" required="provider == 'custom'"
                                   placeholder="e.g. llama3, mixtral, mistral, qwen2.5"/>
                            <field name="api_base_url" invisible="provider != 'custom'"
                                   required="provider == 'custom'"
                                   placeholder="e.g. https://your-server.com/v1"/>
                        </group>
                        <group string="Authentication">
                            <field name="api_key" password="True"/>
                            <field name="last_tested_date"/>
                        </group>
                    </group>
                    <separator string="Data Privacy"/>
                    <group>
                        <group>
                            <field name="anonymize_data"/>
                        </group>
                        <group>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert"
                         invisible="provider != 'custom'">
                        <strong>Custom LLM Setup:</strong> Enter the API URL of your own hosted LLM server.
                        Your server must expose an <b>OpenAI-compatible API</b> 
                        (POST /v1/chat/completions). Compatible with: vLLM, Ollama, LM Studio, 
                        text-generation-webui, LocalAI, or any OpenAI-compatible endpoint.
                        API Key is optional depending on your server configuration.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Credential Tree View -->
    <record id="view_ai_credential_tree" model="ir.ui.view">
        <field name="name">af.credential.list</field>
        <field name="model">af.credential</field>
        <field name="arch" type="xml">
            <list string="AI Credentials">
                <field name="name"/>
                <field name="provider"/>
                <field name="anonymize_data" string="Anonymized"/>
                <field name="status" widget="badge" decoration-success="status == 'valid'" decoration-danger="status == 'invalid'"/>
                <field name="last_tested_date"/>
            </list>
        </field>
    </record>

    <!-- Credential Action -->
    <record id="action_ai_credential" model="ir.actions.act_window">
        <field name="name">AI Credentials</field>
        <field name="res_model">af.credential</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new AI Credential
            </p>
            <p>
                Add credentials for AI providers like Google Gemini, OpenAI, Claude, xAI Grok, 
                Mistral, Cohere, Groq, DeepSeek, or connect your own self-hosted LLM.
            </p>
        </field>
    </record>
</odoo>
