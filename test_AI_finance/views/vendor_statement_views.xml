<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Statement Form View -->
    <record id="view_vendor_statement_form" model="ir.ui.view">
        <field name="name">test.ai.vendor.statement.form</field>
        <field name="model">test.ai.vendor.statement</field>
        <field name="arch" type="xml">
            <form string="Partner Statement">
                <header>
                    <button name="action_match_lines" string="Reconcile with Partner Ledger" type="object" class="oe_highlight" invisible="state == 'reconciled'"/>
                    <button name="action_confirm_matches" string="Confirm Matches" type="object"
                            class="btn-success" invisible="state != 'processed'"/>
                    <button name="action_rematch" string="Re-match" type="object"
                            class="btn-warning" invisible="state == 'draft'"/>
                    <button name="action_print_report" string="Print Report" type="object"
                            class="btn-secondary" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,processed,reconciled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="statement_date"/>
                            <field name="currency_id"/>
                        </group>
                        <group>
                            <field name="statement_total_due"/>
                            <field name="odoo_total_due"/>
                            <field name="difference_amount" decoration-danger="difference_amount != 0"/>
                        </group>
                    </group>
                    <group string="Statement Period">
                        <group>
                            <field name="date_from"/>
                        </group>
                        <group>
                            <field name="date_to"/>
                        </group>
                    </group>
                    <group string="Matching Settings" invisible="not statement_column_ids">
                        <group>
                            <field name="statement_column_ids" invisible="1"/>
                            <field name="selected_column_id"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                        </group>
                        <group>
                            <field name="extracted_columns" invisible="1"/>
                            <field name="match_key_column" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Statement Lines">
                            <field name="line_ids">
                                <list editable="bottom"
                                      decoration-danger="match_status in ('discrepancy', 'missing_in_odoo', 'currency_mismatch')"
                                      decoration-success="match_status == 'matched'"
                                      decoration-warning="match_status in ('missing_in_statement', 'unposted')"
                                      decoration-info="match_status == 'duplicate'">
                                    <field name="date"/>
                                    <field name="name"/>
                                    <field name="voucher_number" optional="show"/>
                                    <field name="amount" sum="Total Statement"/>
                                    <field name="odoo_amount_residual" sum="Total Odoo Open"/>
                                    <field name="matched_move_line_id"
                                           domain="[('id', 'in', candidate_move_line_ids)]"
                                           options="{'no_create': True}"/>
                                    <field name="matched_partner_id" optional="show"/>
                                    <field name="match_status" widget="badge"
                                           decoration-success="match_status == 'matched'"
                                           decoration-danger="match_status in ('missing_in_odoo', 'currency_mismatch')"
                                           decoration-warning="match_status in ('discrepancy', 'unposted')"
                                           decoration-info="match_status == 'duplicate'"/>
                                    <field name="match_notes" optional="hide"/>
                                    <field name="candidate_move_line_ids" column_invisible="True"/>
                                </list>
                            </field>
                        </page>
                        <page string="Reconciliation Summary" invisible="state == 'draft'">
                            <group>
                                <group string="Match Statistics">
                                    <field name="summary_total_lines"/>
                                    <field name="summary_matched" decoration-success="summary_matched > 0"/>
                                    <field name="summary_match_rate" widget="progressbar"/>
                                </group>
                                <group string="Issues Found">
                                    <field name="summary_discrepancy" decoration-danger="summary_discrepancy > 0"/>
                                    <field name="summary_missing_odoo" decoration-danger="summary_missing_odoo > 0"/>
                                    <field name="summary_missing_stmt" decoration-warning="summary_missing_stmt > 0"/>
                                    <field name="summary_unresolved" decoration-danger="summary_unresolved > 0"/>
                                </group>
                            </group>
                        </page>
                        <page string="OCR Raw Data">
                            <field name="ocr_raw_text"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Statement Tree View -->
    <record id="view_vendor_statement_tree" model="ir.ui.view">
        <field name="name">test.ai.vendor.statement.tree</field>
        <field name="model">test.ai.vendor.statement</field>
        <field name="arch" type="xml">
            <list string="Partner Statements">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="statement_date"/>
                <field name="date_from" optional="show"/>
                <field name="date_to" optional="show"/>
                <field name="statement_total_due"/>
                <field name="odoo_total_due"/>
                <field name="difference_amount" decoration-danger="difference_amount != 0"/>
                <field name="state" widget="badge" decoration-success="state == 'processed'"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_vendor_statement_reconciliation" model="ir.actions.act_window">
        <field name="name">Partner Statements</field>
        <field name="res_model">test.ai.vendor.statement</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
